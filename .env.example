# Escrow F71N — DEVNET (hackathon, zero mainnet SOL)

NATT_ESCROW_CLUSTER=devnet
NEXT_PUBLIC_NATT_ESCROW_CLUSTER=devnet
NATT_ESCROW_ENABLED=false
NEXT_PUBLIC_NATT_ESCROW_ENABLED=false
NEXT_PUBLIC_NATT_ESCROW_PROGRAM_ID=GPSU49hPRqWeEtTyMghWLWrXagV8hobFPkbFKVK3jxUD
NATT_ESCROW_PROGRAM_ID=GPSU49hPRqWeEtTyMghWLWrXagV8hobFPkbFKVK3jxUD
SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com
# Optional: HELIUS_API_KEY for devnet.helius-rpc.com (mainnet key does NOT work on devnet)
# Optional: separate TxLINE devnet token (else falls back to TXLINE_API_TOKEN)
# TXLINE_DEV_API_TOKEN=

# F86N edge IP protection — redact pi_model/c/weights from public API (default true)
NATT_EDGE_IP_REDACT=true

NEXT_PUBLIC_NATT_PUNDIT_MCP_URL=https://hypernatt.com/mcp-pundit/protocol
NEXT_PUBLIC_NATT_PUNDIT_MCP_NAME=natt-pundit
NEXT_PUBLIC_AGENT_CONNECT_ENABLED=true
# NEXT_PUBLIC_SMITHERY_SLUG=hypernatt/natt-pundit

# F72N MCP x402 devnet (VPS .env.natt_pundit)
PUNDIT_X402_PAYTO=
PUNDIT_X402_PRICE_USDC=0.01
PUNDIT_X402_INTRO_FREE_ENABLED=true
# Hackathon: all paid tools free on devnet (x402 still works if x_payment sent)
PUNDIT_X402_DEVNET_OPEN_ACCESS=true
# PUNDIT_X402_JURY_BYPASS_WALLETS=<solana-pubkey1>,<solana-pubkey2>

# F77N x402 funnel integrity (defaults safe)
# PUNDIT_X402_SETTLEMENT_CACHE_ENABLED=true
# PUNDIT_X402_SETTLEMENT_CACHE_TTL_SEC=120
# PUNDIT_X402_DELIVER_AFTER_SETTLE_ENABLED=true
# F91N Claude web: session bind OFF by default (Anthropic cloud rotates egress IPs)
# PUNDIT_MCP_SESSION_BIND_ENABLED=false

# F79N submit_signed whitelist (default true)
# PUNDIT_ESCROW_SUBMIT_WHITELIST_ENABLED=true

# F81N Solana RPC proxy allowlist (default true)
# NATT_SOLANA_RPC_PROXY_ENABLED=true

# F76N Live audio commentary (VPS .env.natt_pundit only — never commit keys)
# NATT_COMMENTARY_ENABLED=false
# GOOGLE_CLOUD_TTS_API_KEY=
# GOOGLE_AI_API_KEY=

# Data Lab ZIP export gate (SIWS + allowlist — VPS only)
# NATT_DATAS_EXPORT_TOKEN_SECRET=<random-32+-chars>
# NATT_DATAS_EXPORT_INTERNAL_SECRET=<same-or-different-shared-with-edge-api>
# NATT_DATAS_EXPORT_WHITELIST=<optional-extra-pubkeys-comma-separated>
