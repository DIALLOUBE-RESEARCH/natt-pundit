FROM node:22-alpine AS builder
WORKDIR /app
ARG NEXT_PUBLIC_TXLINE_GATEWAY_URL=https://hypernatt.com/api/natt-pundit/txline
ARG NEXT_PUBLIC_EDGE_API_URL=https://hypernatt.com/api/natt-pundit/edge
ARG NEXT_PUBLIC_COMMENTARY_API_URL=https://hypernatt.com/api/natt-pundit/commentary
ARG NEXT_PUBLIC_NATT_COMMENTARY_ENABLED=false
ARG NEXT_PUBLIC_BASE_PATH=/fr/nattpundit
ARG NEXT_PUBLIC_PROJECT_ID=
ARG NEXT_PUBLIC_NATT_ESCROW_ENABLED=false
ARG NEXT_PUBLIC_NATT_ESCROW_CLUSTER=devnet
ARG NEXT_PUBLIC_NATT_ESCROW_PROGRAM_ID=
ARG SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com
ARG NEXT_PUBLIC_NATT_PUNDIT_MCP_URL=https://hypernatt.com/mcp-pundit/protocol
ARG NEXT_PUBLIC_NATT_PUNDIT_MCP_NAME=natt-pundit
ARG NEXT_PUBLIC_AGENT_CONNECT_ENABLED=true
ARG NEXT_PUBLIC_NATT_PUNDIT_MCP_LIVE=true
ARG NEXT_PUBLIC_SMITHERY_SLUG=
ARG NEXT_PUBLIC_NATT_STITCH_UI_ENABLED=true
ARG NEXT_PUBLIC_NATT_FAN_BET_UX_ENABLED=true
ARG NEXT_PUBLIC_NATT_ESCROW_KEEPER_ENABLED=false
ENV NEXT_PUBLIC_TXLINE_GATEWAY_URL=$NEXT_PUBLIC_TXLINE_GATEWAY_URL
ENV NEXT_PUBLIC_EDGE_API_URL=$NEXT_PUBLIC_EDGE_API_URL
ENV NEXT_PUBLIC_COMMENTARY_API_URL=$NEXT_PUBLIC_COMMENTARY_API_URL
ENV NEXT_PUBLIC_NATT_COMMENTARY_ENABLED=$NEXT_PUBLIC_NATT_COMMENTARY_ENABLED
ENV NEXT_PUBLIC_BASE_PATH=$NEXT_PUBLIC_BASE_PATH
ENV NEXT_PUBLIC_PROJECT_ID=$NEXT_PUBLIC_PROJECT_ID
ENV NEXT_PUBLIC_NATT_ESCROW_ENABLED=$NEXT_PUBLIC_NATT_ESCROW_ENABLED
ENV NEXT_PUBLIC_NATT_ESCROW_CLUSTER=$NEXT_PUBLIC_NATT_ESCROW_CLUSTER
ENV NEXT_PUBLIC_NATT_ESCROW_PROGRAM_ID=$NEXT_PUBLIC_NATT_ESCROW_PROGRAM_ID
ENV SOLANA_DEVNET_RPC_URL=$SOLANA_DEVNET_RPC_URL
ENV NEXT_PUBLIC_NATT_PUNDIT_MCP_URL=$NEXT_PUBLIC_NATT_PUNDIT_MCP_URL
ENV NEXT_PUBLIC_NATT_PUNDIT_MCP_NAME=$NEXT_PUBLIC_NATT_PUNDIT_MCP_NAME
ENV NEXT_PUBLIC_AGENT_CONNECT_ENABLED=$NEXT_PUBLIC_AGENT_CONNECT_ENABLED
ENV NEXT_PUBLIC_NATT_PUNDIT_MCP_LIVE=$NEXT_PUBLIC_NATT_PUNDIT_MCP_LIVE
ENV NEXT_PUBLIC_SMITHERY_SLUG=$NEXT_PUBLIC_SMITHERY_SLUG
ENV NEXT_PUBLIC_NATT_STITCH_UI_ENABLED=$NEXT_PUBLIC_NATT_STITCH_UI_ENABLED
ENV NEXT_PUBLIC_NATT_FAN_BET_UX_ENABLED=$NEXT_PUBLIC_NATT_FAN_BET_UX_ENABLED
ENV NEXT_PUBLIC_NATT_ESCROW_KEEPER_ENABLED=$NEXT_PUBLIC_NATT_ESCROW_KEEPER_ENABLED
COPY package.json package-lock.json* .npmrc ./
COPY packages ./packages
COPY apps/web ./apps/web
RUN npm install -w @natt-pundit/web
RUN npm run build -w @natt-pundit/contracts && npm run build -w @natt-pundit/natt-core && npm run build -w @natt-pundit/web

FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ARG SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com
ENV SOLANA_DEVNET_RPC_URL=$SOLANA_DEVNET_RPC_URL
ENV SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public
EXPOSE 3000
CMD ["node", "apps/web/server.js"]
